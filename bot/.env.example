TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# Where the bot should send results/errors.
# Recommended: set this to your own user id (DM chat id), so the bot never posts in the group.
# If empty, the bot will try to DM the user who triggered the group message.
TELEGRAM_NOTIFY_CHAT_ID=

BACKEND_BASE_URL=http://localhost:8000
BACKEND_INTERNAL_SECRET=change-me
