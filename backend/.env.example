# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/automate_trading
# SQLite fallback (optional):
# DATABASE_URL=sqlite:///./data.db
CORS_ORIGINS=http://localhost:4200

# Required: 32-byte base64 key from cryptography.Fernet.generate_key()
TOKEN_ENCRYPTION_KEY=

# Shared secret used by Telegram bot to call /api/telegram/ingest
INTERNAL_SECRET=change-me

# Shared secret used by the webapp admin page to list/delete users
ADMIN_SECRET=change-me

# Upstox base URL
UPSTOX_BASE_URL=https://api.upstox.com

# Upstox OAuth base URL (v2 host for auth/token)
UPSTOX_OAUTH_BASE_URL=https://api-v2.upstox.com

# For local testing without hitting real Upstox, point base URL to the backend mock:
# UPSTOX_BASE_URL=http://127.0.0.1:8000/mock/upstox

# Optional: If you have an exchange-approved algo name
UPSTOX_X_ALGO_NAME=

# Optional: Server-side Upstox OAuth configuration. When set, the backend will
# provide an auth URL at `GET /api/upstox/auth-url` and handle the callback at
# `GET /api/upstox/callback` to exchange the code and store the access token.
# Register the exact redirect URI with Upstox (e.g. https://your-server.com/api/upstox/callback)
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_REDIRECT_URI=
WEBAPP_BASE_URL=http://localhost:4200

# User auth session and OTP configuration
AUTH_SESSION_HOURS=168
OTP_EXPIRY_MINUTES=10

# Gmail SMTP configuration for password reset OTP emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=160220b057@gmail.com
SMTP_PASSWORD=tepy ahed skcb hkvo
SMTP_FROM_EMAIL=160220b057@gmail.com
